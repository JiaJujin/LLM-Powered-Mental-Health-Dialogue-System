# ===== Zhipu BigModel API (Required) =====
# Used for: emotion classification, crisis detection, B1/B2/B3 therapy, insights
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.5-air

# ===== Speech-to-Text (Optional) =====
# Option A: OpenAI Whisper (higher quality, requires API key)
#   - Get key at: https://platform.openai.com/api-keys
#   - Audio transcription via Whisper-1 model
OPENAI_API_KEY=your_openai_api_key_here

# Option B: Google Speech Recognition (free fallback, no key needed)
#   - Works without any API key
#   - Requires internet connection
#   - pip install SpeechRecognition  (already in requirements.txt)
#   - Note: Only supports audio clips < 60 seconds

# ===== OCR / Vision (Optional but recommended) =====
# Handwritten diary image OCR uses the existing Zhipu GLM-4V model.
# No additional API key needed — reuses ZHIPU_API_KEY above.
# Model: glm-4v-plus (called inside services/ocr_service.py)

# ===== Server =====
# PORT=8000  (default, no need to set unless you want a different port)
# HOST=0.0.0.0  (default binds to all interfaces)
